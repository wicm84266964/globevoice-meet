{
  "name": "globevoice-meet",
  "private": true,
  "version": "1.0.0",
  "description": "面向跨国会议的实时同声传译桌面助手，基于 Electron、React 与 Python 后端。",
  "author": "GlobeVoice Meet Contributors",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "build:all": "python ../backend/build_backend.py && npm run electron:build"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.4",
    "electron": "^40.8.5",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.5",
    "wait-on": "^9.0.3"
  },
  "build": {
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "appId": "com.globevoice.meet",
    "productName": "GlobeVoice Meet",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "../release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GlobeVoice Meet"
    },
    "portable": {
      "artifactName": "${productName}-便携版-${version}.exe"
    },
    "extraResources": [
      {
        "from": "../dist/backend_engine.exe",
        "to": "backend_engine.exe"
      }
    ]
  }
}
